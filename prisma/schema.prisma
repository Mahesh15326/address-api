generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  states    State[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model State {
  id          Int               @id @default(autoincrement())
  name        String
  code        String            @unique
  countryId   Int
  country     Country           @relation(fields: [countryId], references: [id])
  districts   District[]
  userAccess  UserStateAccess[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model District {
  id           Int           @id @default(autoincrement())
  name         String
  code         String        @unique
  stateId      Int
  state        State         @relation(fields: [stateId], references: [id])
  subDistricts SubDistrict[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SubDistrict {
  id         Int       @id @default(autoincrement())
  name       String
  code       String    @unique
  districtId Int
  district   District  @relation(fields: [districtId], references: [id])
  villages   Village[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Village {
  id            Int         @id @default(autoincrement())
  name          String
  code          String      @unique
  subDistrictId Int
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model User {
  id          Int               @id @default(autoincrement())
  email       String            @unique
  password    String
  planType    String            @default("FREE")
  isActive    Boolean           @default(true)
  apiKeys     ApiKey[]
  apiLogs     ApiLog[]
  stateAccess UserStateAccess[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  name       String
  key        String    @unique
  secretHash String
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  apiLogs    ApiLog[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model UserStateAccess {
  id      Int   @id @default(autoincrement())
  userId  Int
  stateId Int
  user    User  @relation(fields: [userId], references: [id])
  state   State @relation(fields: [stateId], references: [id])

  @@unique([userId, stateId])
}

model ApiLog {
  id           Int      @id @default(autoincrement())
  endpoint     String
  responseTime Int
  statusCode   Int
  userId       Int
  apiKeyId     Int
  user         User     @relation(fields: [userId], references: [id])
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id])
  createdAt    DateTime @default(now())
}